generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum CustomerType {
  RETAIL
  WHOLESALE
  RESTAURANT
  DISTRIBUTOR
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  OUT_OF_STOCK
  FUTURE
  ARCHIVED
}

enum CartStatus {
  ACTIVE
  CONVERTED
  ABANDONED
  EXPIRED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  PREPARING
  READY
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  REFUNDED
}

enum InventoryMovementType {
  ENTRY
  RESERVATION
  RELEASE
  SALE
  ADJUSTMENT
  RETURN
  LOSS
  DAMAGE
  EXPIRATION
}

enum WholesaleStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

enum ContactStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                        String   @id @default(cuid())
  email                     String   @unique
  username                  String?  @unique
  passwordHash              String
  firstName                 String
  lastName                  String
  birthDate                 DateTime?
  phone                     String?
  city                      String?
  status                    UserStatus @default(PENDING)
  customerType              CustomerType @default(RETAIL)
  termsAcceptedAt           DateTime?
  dataProcessingAcceptedAt  DateTime?
  commercialConsent         Boolean @default(false)
  emailVerifiedAt           DateTime?
  lastLoginAt               DateTime?
  tokenVersion              Int @default(0)
  deletedAt                 DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  roles                     UserRole[]
  addresses                 Address[]
  emailVerificationTokens   EmailVerificationToken[]
  passwordResetTokens       PasswordResetToken[]
  refreshSessions           RefreshSession[]
  favoriteProducts          FavoriteProduct[]
  favoriteRecipes           FavoriteRecipe[]
  carts                     Cart[]
  orders                    Order[]
  orderStatusChanges        OrderStatusHistory[] @relation("OrderStatusActor")
  inventoryMovements        InventoryMovement[] @relation("InventoryActor")
  wholesaleRequests         WholesaleRequest[] @relation("WholesaleApplicant")
  reviewedWholesaleRequests WholesaleRequest[] @relation("WholesaleReviewer")
  testimonials              Testimonial[]
  publications              Publication[]
  recipes                   Recipe[] @relation("RecipeAuthor")
  reviews                   ProductReview[]
  auditLogs                 AuditLog[]

  @@index([status])
  @@index([customerType])
  @@index([deletedAt])
}

model RefreshSession {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       UserRole[]
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
}

model Address {
  id          String   @id @default(cuid())
  userId      String
  label       String?
  recipient   String
  phone       String
  line1       String
  line2       String?
  city        String
  department  String
  postalCode  String?
  instructions String?
  isDefault   Boolean  @default(false)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isDefault])
  @@index([deletedAt])
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Product {
  id                 String   @id @default(cuid())
  name               String
  slug               String   @unique
  sku                String   @unique
  description        String
  presentation       String
  priceInCents       Int
  wholesalePriceInCents Int?
  minimumWholesaleQuantity Int @default(1)
  featured           Boolean @default(false)
  wholesaleOnly      Boolean @default(false)
  stock              Int @default(0)
  minimumStock       Int @default(0)
  viewCount          Int @default(0)
  status             ProductStatus @default(DRAFT)
  deletedAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  images             ProductImage[]
  videos             ProductVideo[]
  categories         ProductCategory[]
  favoriteBy         FavoriteProduct[]
  cartItems          CartItem[]
  orderItems         OrderItem[]
  inventoryMovements InventoryMovement[]
  discounts          Discount[]
  reviews            ProductReview[]

  @@index([status, deletedAt])
  @@index([wholesaleOnly])
}

model ProductImage {
  id        String   @id @default(cuid())
  productId String
  url       String
  altText   String
  sortOrder Int @default(0)
  isPrimary Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductVideo {
  id          String   @id @default(cuid())
  productId   String
  url         String
  title       String?
  provider    String?
  sortOrder   Int @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  isActive    Boolean @default(true)
  sortOrder   Int @default(0)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    ProductCategory[]

  @@index([isActive, sortOrder])
}

model ProductCategory {
  id         String   @id @default(cuid())
  productId  String
  categoryId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([productId, categoryId])
  @@index([categoryId])
}

model Recipe {
  id          String   @id @default(cuid())
  authorId    String?
  title       String
  slug        String   @unique
  summary     String
  preparationTimeMinutes Int?
  servings    Int?
  difficulty  String?
  videoUrl    String?
  imageUrl    String?
  status      ContentStatus @default(DRAFT)
  viewCount   Int @default(0)
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User? @relation("RecipeAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  ingredients RecipeIngredient[]
  steps       RecipeStep[]
  categories  RecipeCategory[]
  favoriteBy  FavoriteRecipe[]

  @@index([status, publishedAt])
  @@index([authorId])
}

model RecipeIngredient {
  id        String   @id @default(cuid())
  recipeId  String
  name      String
  quantity  String?
  sortOrder Int @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId, sortOrder])
}

model RecipeStep {
  id          String   @id @default(cuid())
  recipeId    String
  instruction String
  sortOrder   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  recipe      Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, sortOrder])
}

model RecipeCategory {
  id        String   @id @default(cuid())
  recipeId  String
  name      String
  slug      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([recipeId, slug])
  @@index([slug])
}

model FavoriteProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId])
}

model FavoriteRecipe {
  id        String   @id @default(cuid())
  userId    String
  recipeId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([userId, recipeId])
  @@index([recipeId])
}

model Cart {
  id        String   @id @default(cuid())
  userId    String?
  sessionId String?  @unique
  status    CartStatus @default(ACTIVE)
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[]

  @@index([userId, status])
  @@index([expiresAt])
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String
  productId String
  quantity  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([cartId, productId])
  @@index([productId])
}

model Order {
  id                 String   @id @default(cuid())
  number             String   @unique
  userId             String?
  status             OrderStatus @default(PENDING)
  customerType       CustomerType @default(RETAIL)
  customerName       String
  customerEmail      String
  customerPhone      String?
  shippingAddress    String?
  deliveryType       String?
  paymentMethod      String?
  billingData        String?
  subtotalInCents    Int
  discountInCents    Int @default(0)
  shippingInCents    Int @default(0)
  totalInCents       Int
  currency           String @default("COP")
  notes              String?
  internalNotes      String?
  cancelledAt        DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  items              OrderItem[]
  statusHistory      OrderStatusHistory[]
  payments           Payment[]
  couponRedemptions  CouponRedemption[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  productId        String?
  productName      String
  sku              String
  presentation     String
  quantity         Int
  unitPriceInCents Int
  totalInCents     Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  order            Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model OrderStatusHistory {
  id        String   @id @default(cuid())
  orderId   String
  actorId   String?
  fromStatus OrderStatus?
  toStatus  OrderStatus
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order     Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor     User? @relation("OrderStatusActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt])
  @@index([actorId])
}

model Payment {
  id                 String   @id @default(cuid())
  orderId            String
  provider           String
  externalReference  String? @unique
  status             PaymentStatus @default(PENDING)
  amountInCents      Int
  currency           String @default("COP")
  method             String?
  paidAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  order              Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId, status])
  @@index([createdAt])
}

model InventoryMovement {
  id        String   @id @default(cuid())
  productId String
  actorId   String?
  type      InventoryMovementType
  quantity  Int
  reason    String?
  reference String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  actor     User? @relation("InventoryActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([type, createdAt])
}

model WholesaleRequest {
  id                    String   @id @default(cuid())
  applicantId           String?
  reviewedById          String?
  businessName          String
  contactName           String
  email                 String
  phone                 String
  businessType          CustomerType
  city                  String
  estimatedVolumeKg     Int?
  message               String?
  status                WholesaleStatus @default(PENDING)
  reviewedAt            DateTime?
  internalNotes         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  applicant             User? @relation("WholesaleApplicant", fields: [applicantId], references: [id], onDelete: SetNull)
  reviewedBy            User? @relation("WholesaleReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([email])
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String?
  message   String
  status    ContactStatus @default(NEW)
  consent   Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
  @@index([email])
}

model Testimonial {
  id          String   @id @default(cuid())
  userId      String?
  authorName  String
  content     String
  rating      Int?
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
}

model Publication {
  id          String   @id @default(cuid())
  authorId    String?
  title       String
  slug        String   @unique
  excerpt     String?
  content     String
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  author      User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([status, publishedAt])
  @@index([authorId])
}

model SiteSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  type        String @default("text")
  description String?
  isPublic    Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  sortOrder Int      @default(0)
  status    ContentStatus @default(DRAFT)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, sortOrder])
  @@index([deletedAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  changesJson String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([entity, entityId])
  @@index([userId, createdAt])
  @@index([createdAt])
}

model Discount {
  id             String   @id @default(cuid())
  name           String
  type           DiscountType
  value          Int
  productId      String?
  startsAt       DateTime
  endsAt         DateTime?
  isActive       Boolean @default(true)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  product        Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  coupons        Coupon[]

  @@index([isActive, startsAt, endsAt])
  @@index([productId])
}

model Coupon {
  id          String   @id @default(cuid())
  discountId  String
  code        String   @unique
  maxUses     Int?
  uses        Int @default(0)
  startsAt    DateTime
  expiresAt   DateTime?
  isActive    Boolean @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  discount    Discount @relation(fields: [discountId], references: [id], onDelete: Cascade)
  redemptions CouponRedemption[]

  @@index([isActive, startsAt, expiresAt])
}

model CouponRedemption {
  id        String   @id @default(cuid())
  couponId  String
  orderId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  coupon    Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)
  order     Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([couponId, orderId])
  @@index([orderId])
}

model ProductReview {
  id          String   @id @default(cuid())
  userId      String
  productId   String
  rating      Int
  title       String?
  comment     String?
  status      ReviewStatus @default(PENDING)
  publishedAt DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  product     Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([productId, status])
  @@index([status, createdAt])
}
